# ─────────────────────────────────────────────────────────────────────────────
# More Dutch — monorepo root environment template
#
# SETUP:
#   1. Copy this file to .env in the root:         cp .env.example .env
#   2. Copy the API template to apps/api/.env:     cp apps/api/.env.example apps/api/.env
#   3. Fill in any secret values (COOKIE_SECRET, DATABASE_URL for prod, etc.)
#
# The API (NestJS) loads apps/api/.env first, then falls back to this file.
# DATABASE_URL should be set in apps/api/.env so the relative path resolves
# correctly from the apps/api/ directory on any machine.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Web (Angular SSR) ─────────────────────────────────────────────────────────
SITE_URL=http://localhost:4200

# ── API (NestJS) ──────────────────────────────────────────────────────────────
PORT=3000
COOKIE_SECRET=change-me-to-a-long-random-string-min-32-chars
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:4200

# ── Database ──────────────────────────────────────────────────────────────────
# NOTE: Set DATABASE_URL in apps/api/.env instead of here.
# If you must set it here, use an absolute path or a path relative to apps/api/:
#   Development (SQLite):  DATABASE_URL=file:./prisma/dev.db  ← set in apps/api/.env
#   Production (Postgres): DATABASE_URL=postgresql://user:pass@host:5432/moredutch
DATABASE_URL=file:./prisma/dev.db
