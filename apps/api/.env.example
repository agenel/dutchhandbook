# ─────────────────────────────────────────────
# More Dutch — API environment (apps/api/.env)
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

NODE_ENV=development

# ── Server ───────────────────────────────────
PORT=3000
COOKIE_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:4200

# ── Database ─────────────────────────────────
# For local SQLite development (path relative to apps/api/)
DATABASE_URL=file:./prisma/dev.db

# For production PostgreSQL, replace with:
# DATABASE_URL=postgresql://user:password@host:5432/moredutch
