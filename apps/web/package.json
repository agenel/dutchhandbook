    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/platform-server": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@angular/ssr": "^21.2.8",
    "@moredutch/shared": "*",
    "@primeng/themes": "^21.0.4",
    "express": "^4.21.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.1",
    "tslib": "^2.7.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.8",
