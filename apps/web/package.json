{
  "name": "@moredutch/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && node ../../scripts/generate-sitemap.mjs",
    "watch": "ng build --watch --configuration development",
